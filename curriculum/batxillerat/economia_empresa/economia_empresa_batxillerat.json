  "competencies_especifiques": [
    {
      "codi": "CE1",
      "text": "Analitzar l'empresa com a sistema obert en interacció amb el seu entorn, identificant els factors que determinen la seva forma jurídica, localització i dimensió.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA1.1",
            "text": "Classifica les empreses per sectors, mida, forma jurídica i titularitat, relacionant cada tipus amb les seves implicacions legals i fiscals.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA1.2",
            "text": "Analitza el macroentorn d'una empresa real aplicant el model PESTEL, identificant les variables que més condicionen la seva activitat.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA1.3",
            "text": "Aplica el model de les cinc forces de Porter per analitzar el microentorn i el grau d'atractivitat d'un sector empresarial concret.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA1.4",
            "text": "Argumenta crítica la responsabilitat social corporativa (RSC) d'una empresa, valorant el seu impacte econòmic, social i mediambiental.",
            "clau_origen": "2n"
          }
        ]
      }
    },
    {
      "codi": "CE2",
      "text": "Comprendre i analitzar l'organització interna de l'empresa (funcions, departaments, estructura) per valorar la seva eficiència i proposar-ne millores.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA2.1",
            "text": "Identifica les àrees funcionals d'una empresa i descriu les activitats principals de cadascuna, relacionant-les amb els objectius globals.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA2.2",
            "text": "Analitza i compara estructures organitzatives (lineal, funcional, matricial) a partir d'organogrames reals, valorant els avantatges i limitacions de cada model.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA2.3",
            "text": "Descriu els processos de planificació, organització, gestió i control (PODC) i en reconeix la presència en la gestió d'una empresa real.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA2.4",
            "text": "Valora el paper de la cultura organitzativa, els valors i el lideratge en el rendiment i el benestar de les persones en l'empresa.",
            "clau_origen": "2n"
          }
        ]
      }
    },
    {
      "codi": "CE3",
      "text": "Dissenyar i avaluar estratègies de màrqueting mix per a productes o serveis, analitzant el mercat i el comportament del consumidor per maximitzar la proposta de valor.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA3.1",
            "text": "Realitza una investigació de mercat senzilla, aplicant tècniques de recerca (enquesta, entrevista, observació) i analitzant els resultats obtinguts.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA3.2",
            "text": "Dissenya el màrqueting mix (producte, preu, distribució, comunicació) per a un producte o servei, justificant cada decisió en funció del target.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA3.3",
            "text": "Analitza una campanya de publicitat real, identificant el missatge, el públic objectiu, els canals emprats i l'eficàcia de la comunicació.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA3.4",
            "text": "Reflexiona sobre el màrqueting digital i les xarxes socials com a canals de comunicació i venda, valorant els seus avantatges, riscos i implicacions ètiques.",
            "clau_origen": "2n"
          }
        ]
      }
    },
    {
      "codi": "CE4",
      "text": "Analitzar la situació econòmico-financera d'una empresa a partir dels estats comptables per avaluar-ne la solvència, la rendibilitat i el financement.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA4.1",
            "text": "Interpreta el balanç de situació d'una empresa, identificant l'actiu, el passiu i el patrimoni net, i analitzant l'equilibri financer a curt i llarg termini.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA4.2",
            "text": "Analitza el compte de resultats, calculant el resultat d'explotació, el resultat financer i el resultat net, i interpretant-ne la tendència.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA4.3",
            "text": "Calcula i interpreta els ratiós econòmics i financers bàsics (liquiditat, solvència, rendibilitat econòmica i financera, endeutament).",
            "clau_origen": "2n"
          },
          {
            "codi": "CA4.4",
            "text": "Compara les fonts de financement (pròpies, ajenes, a curt i llarg termini) i raona quina és més adequada per a diferents situacions de l'empresa.",
            "clau_origen": "2n"
          }
        ]
      }
    },
    {
      "codi": "CE5",
      "text": "Analitzar la gestió dels recursos humans i el lideratge a l'empresa, valorant la motivació, la retribució i les relacions laborals com a factors clau de la competitivitat.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA5.1",
            "text": "Descriu el procés de selecció i contractació del personal, identificant les modalitats contractuals, les obligacions legals i els drets dels treballadors.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA5.2",
            "text": "Aplica les principals teories de la motivació laboral (Maslow, Herzberg, McGregor) a casos pràctics, proposant polítiques de motivació adequades.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA5.3",
            "text": "Analitza el conveni col·lectiu del sector estudiat, identificant les condicions salarials, la jornada i els mecanismes de resolució de conflictes laborals.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA5.4",
            "text": "Reflexiona sobre la igualtat d'oportunitats, la conciliació laboral i familiar i la diversitat a l'empresa com a factors d'equitat i millora del clima organitzatiu.",
            "clau_origen": "2n"
          }
        ]
      }
    },
    {
      "codi": "CE6",
      "text": "Elaborar i valorar un pla d'empresa o d'emprenedoria, integrant les decisions estratègiques, comercials, financeres i organitzatives en un projecte coherent i viable.",
      "criteris_avaluacio": {
        "BAT_1R": [],
        "BAT_2N": [
          {
            "codi": "CA6.1",
            "text": "Realitza una anàlisi DAFO d'una empresa o idea de negoci, identificant fortaleses, debilitats, amenaces i oportunitats, i extraient conclusions estratègiques.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA6.2",
            "text": "Defineix la missió, la visió, els valors i els objectius estratègics d'una empresa, alineant-los amb la seva proposta de valor.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA6.3",
            "text": "Elabora un pla de negoci breu (lean canvas o business model canvas) per a una idea innovadora, incloent-hi el model d'ingressos i l'anàlisi de viabilitat bàsica.",
            "clau_origen": "2n"
          },
          {
            "codi": "CA6.4",
            "text": "Presenta el pla d'empresa de forma oral i argumentada, responent a preguntes crítiques sobre la viabilitat, els riscos i les oportunitats de la proposta.",
            "clau_origen": "2n"
          }
        ]
      }
    }
  ],
